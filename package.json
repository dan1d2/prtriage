{
  "name": "pr-triage-bot",
  "version": "0.1.0",
  "description": "PR Triage Bot - Never miss the next PR to review",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "vercel-build": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "db:migrate": "node dist/db/migrate.js",
    "db:seed": "node dist/db/seed.js",
    "docker:build": "docker build -t pr-triage-bot .",
    "docker:run": "docker run -p 3000:3000 --env-file .env pr-triage-bot"
  },
  "keywords": [
    "github",
    "slack",
    "pr",
    "code-review",
    "engineering",
    "productivity"
  ],
  "author": "dan1d2",
  "license": "MIT",
  "dependencies": {
    "@octokit/webhooks": "^12.0.0",
    "@slack/bolt": "^3.17.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "winston": "^3.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0",
    "tsx": "^3.12.0",
    "typescript": "^5.1.0",
    "vitest": "^0.34.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dan1d2/prtriage.git"
  },
  "bugs": {
    "url": "https://github.com/dan1d2/prtriage/issues"
  },
  "homepage": "https://github.com/dan1d2/prtriage#readme"
}