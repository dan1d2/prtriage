# ============================================
# PR TRIAGE BOT - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ====================
# GITHUB CONFIGURATION
# ====================

# GitHub App ID (from GitHub App settings)
GITHUB_APP_ID=your_app_id_here

# GitHub App Private Key (download .pem file, then copy contents)
# Format: -----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_PRIVATE_KEY=your_private_key_here

# GitHub App Webhook Secret (generate in GitHub App settings)
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App Client ID (from GitHub App settings)
GITHUB_APP_CLIENT_ID=your_client_id_here

# GitHub App Client Secret (from GitHub App settings)
GITHUB_APP_CLIENT_SECRET=your_client_secret_here

# ====================
# SLACK CONFIGURATION
# ====================

# Slack Bot Token (xoxb-... from Slack App OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-your_bot_token_here

# Slack Signing Secret (from Slack App Basic Information)
SLACK_SIGNING_SECRET=your_signing_secret_here

# Slack App Token (xapp-... for Socket Mode, optional but recommended)
SLACK_APP_TOKEN=xapp-your_app_token_here

# ====================
# DATABASE CONFIGURATION
# ====================

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
# For Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# For Neon: postgresql://[USER]:[PASSWORD]@[ENDPOINT]/[DATABASE]
DATABASE_URL=postgresql://user:password@localhost:5432/prtriage

# Redis URL (for caching and rate limiting)
# Format: redis://user:password@host:port
# For Upstash: redis://default:[TOKEN]@[ENDPOINT]:[PORT]
REDIS_URL=redis://localhost:6379

# ====================
# SERVER CONFIGURATION
# ====================

# Server Port
PORT=3000

# Node Environment
NODE_ENV=production

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Application URL (your Vercel deployment URL)
APP_URL=https://prtriage.vercel.app

# ====================
# SLACK CHANNEL CONFIG
# ====================

# Default Slack channel for notifications
SLACK_CHANNEL_ID=#engineering

# ====================
# NOTIFICATION SETTINGS
# ====================

# Cooldown between notifications (minutes)
NOTIFICATION_COOLDOWN_MINUTES=5

# Daily digest hour (24-hour format)
DIGEST_HOUR=9

# Daily digest timezone
DIGEST_TIMEZONE=America/New_York

# ====================
# SECURITY
# ====================

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here-change-in-production

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-here-change-in-production

# ====================
# RATE LIMITING
# ====================

# Rate limit window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ====================
# GITHUB REPO CONFIG
# ====================

# Comma-separated list of GitHub repositories to monitor
# Format: owner/repo,owner/repo
GITHUB_REPOSITORIES=dan1d2/prtriage,dan1d2/autos-argentina

# ====================
# FEATURE FLAGS
# ====================

# Enable/disable features
FEATURE_SLACK_NOTIFICATIONS=true
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_DAILY_DIGEST=true
FEATURE_AUTO_ASSIGN_REVIEWERS=true

# ============================================
# NOTES:
# ============================================
# 1. For GitHub Private Key:
#    - Download .pem file from GitHub App settings
#    - Convert to single line: sed -z 's/\n/\\n/g' private-key.pem
#    - Or use: cat private-key.pem | tr '\n' '\\n'
#
# 2. For Slack Socket Mode:
#    - Enable Socket Mode in Slack App settings
#    - Generate app-level token (xapp-...)
#    - Add "connections:write" scope
#
# 3. For Database:
#    - Free options: Supabase (PostgreSQL) + Upstash (Redis)
#    - Local: docker-compose up -d
#
# 4. For Vercel:
#    - Add all these variables in Project Settings → Environment Variables
#    - Redeploy after adding variables
# ============================================